# syntax=docker/dockerfile:1

# UBI 8 (glibc 2.28) = manylinux_2_28 baseline; multi-arch; no PPA / no
# api.launchpad.net dependency.
ARG CUDA_BASE_TAG=12.8.1-devel-ubi8
FROM nvcr.io/nvidia/cuda:${CUDA_BASE_TAG} AS build

ARG max_jobs=16
ARG torch_cuda_arch_list="8.7 8.9 9.0 10.0+PTX"
ARG TORCH_VERSION=2.10.0
ARG TORCH_CUDA_INDEX=cu128
ARG WHEEL_LOCAL_VERSION=
ARG PYTHON_VERSION=3.12

# System build deps. EPEL is required for numactl-devel + patchelf, which
# UBI 8's default repos don't ship. patchelf is needed by auditwheel.
RUN dnf install -y --setopt=install_weak_deps=False \
      https://dl.fedoraproject.org/pub/epel/epel-release-latest-8.noarch.rpm && \
    dnf install -y --setopt=install_weak_deps=False \
      gcc gcc-c++ make ninja-build \
      numactl-devel \
      patchelf \
      git curl ca-certificates xz \
    && dnf clean all && rm -rf /var/cache/dnf

# Install Python via uv. uv ships standalone, hermetic Python interpreters
# for both amd64 and arm64, so the same Dockerfile works on every runner
# without depending on distro Python packaging.
RUN curl -LsSf https://astral.sh/uv/install.sh | sh && \
    /root/.local/bin/uv python install ${PYTHON_VERSION} && \
    /root/.local/bin/uv venv /opt/venv --python ${PYTHON_VERSION}
ENV PATH=/opt/venv/bin:/root/.local/bin:${PATH}
ENV VIRTUAL_ENV=/opt/venv

# CUDA env (must be set for torch.utils.cpp_extension)
ENV CUDA_HOME=/usr/local/cuda
ENV PATH=${CUDA_HOME}/bin:${PATH}
ENV LD_LIBRARY_PATH=${CUDA_HOME}/lib64:${LD_LIBRARY_PATH}
ENV TORCH_CUDA_ARCH_LIST=${torch_cuda_arch_list}
ENV MAX_JOBS=${max_jobs}
# Enable -static-libstdc++ for the redistributable wheel (read by setup.py).
ENV FS_PORTABLE_WHEEL=1

# Python build deps + auditwheel.
RUN python -m pip install --upgrade pip setuptools wheel ninja numpy auditwheel

# Install torch (CUDA index + version controlled by build args).
RUN python -m pip install --no-cache-dir \
      --index-url https://download.pytorch.org/whl/${TORCH_CUDA_INDEX} \
      torch==${TORCH_VERSION}

# Copy source code
WORKDIR /workspace
COPY . /workspace/

# Append WHEEL_LOCAL_VERSION (e.g. "+cu130") to the version in
# pyproject.toml before building, so the wheel's filename and internal
# METADATA stay in sync — pip rejects wheels where they disagree.
RUN if [ -n "${WHEEL_LOCAL_VERSION}" ]; then \
      sed -i -E "0,/^version *= *\"[^\"]+\"/{s/^(version *= *\")([^\"]+)(\")/\\1\\2${WHEEL_LOCAL_VERSION}\\3/}" pyproject.toml && \
      grep '^version' pyproject.toml ; \
    fi

# Optional: sanity checks (helps debug CUDA_HOME / nvcc / torch)
RUN echo "CUDA_HOME=$CUDA_HOME" && \
    which nvcc && nvcc --version && \
    python -c "import os; print('CUDA_HOME=', os.environ.get('CUDA_HOME')); import torch; print('torch cuda=', torch.version.cuda)"

# Build wheel as cp38-abi3 (Python 3.8 stable ABI; one .so works on any
# cpython 3.8+, mirrors vLLM's wheel naming).
RUN rm -rf build dist-raw dist *.egg-info && \
    mkdir -p dist-raw dist && \
    python setup.py bdist_wheel --py-limited-api=cp38 -d dist-raw

# auditwheel: turn the raw linux_<arch> wheel into a manylinux_2_28_<arch>
# wheel. It bundles small non-system .so deps (e.g. libnuma) into the wheel
# and verifies no symbol requires glibc > 2.28. torch + CUDA libs are
# excluded — they're already loaded from the user's torch install at runtime,
# so bundling them would bloat the wheel by ~2 GB and create conflicting
# copies of libtorch_cuda / libc10 in the same process.
RUN auditwheel show dist-raw/*.whl && \
    auditwheel repair \
      --plat manylinux_2_28_$(uname -m) \
      --exclude 'libtorch*.so*' \
      --exclude 'libc10*.so*' \
      --exclude 'libcuda*.so*' \
      --exclude 'libcublas*.so*' \
      --exclude 'libcublasLt*.so*' \
      --exclude 'libcufile*.so*' \
      --exclude 'libnvToolsExt*.so*' \
      -w dist dist-raw/*.whl && \
    ls -lh dist/
